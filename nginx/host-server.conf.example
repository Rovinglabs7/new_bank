# Copy to /etc/nginx/sites-available/new-bank and symlink to sites-enabled.
# Replace DEPLOY_PATH, SITE_HOST, API_HOST, and SSL certificate paths.

include DEPLOY_PATH/nginx/host-upstream.conf;

map $http_upgrade $connection_upgrade {
    default upgrade;
    ""      close;
}

# --- HTTP → HTTPS (site) ---
server {
    listen 80;
    listen [::]:80;
    server_name SITE_HOST www.SITE_HOST;
    location / { return 301 https://$host$request_uri; }
}

# --- HTTP → HTTPS (API) ---
server {
    listen 80;
    listen [::]:80;
    server_name API_HOST;
    location / { return 301 https://$host$request_uri; }
}

# --- Production site (Next.js) ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name SITE_HOST www.SITE_HOST;

    ssl_certificate /etc/letsencrypt/live/SITE_HOST/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/SITE_HOST/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
    client_max_body_size 10M;

    location / {
        proxy_pass http://new-bank_web;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 60s;
        proxy_connect_timeout 10s;
    }
}

# --- Production API (FastAPI) ---
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name API_HOST;

    ssl_certificate /etc/letsencrypt/live/API_HOST/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/API_HOST/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
    client_max_body_size 2M;

    location / {
        proxy_pass http://new-bank_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 60s;
        proxy_connect_timeout 10s;
    }
}
