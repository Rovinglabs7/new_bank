# VPS production environment — copy to .env on the server (never commit .env)
# Cloudflare Workers use dashboard vars for dev; this file is production only.

# --- PostgreSQL ---
POSTGRES_PASSWORD=235ad3c55683d98eda9faad27f71322e96c6c0bcabb440c5723ce00a351962ff
POSTGRES_DB=new_bank
POSTGRES_USER=new_bank

# --- Domains ---
SITE_HOST=prod.praevortech.com
API_HOST=api.praevortech.com
SITE_URL=https://prod.praevortech.com
API_URL=https://api.praevortech.com

# --- Auth (must match between Next.js and FastAPI) ---
JWT_SECRET=replace-with-a-long-random-secret

# --- Frontend production ---
MOCK_MODE=false

# --- Backend CORS (browser origins allowed to call the API) ---
CORS_ORIGINS=https://prod.praevortech.com,https://www.prod.praevortech.com

# --- Blue-green host bind ports (pick unused ports on your VPS) ---
WEB_BLUE_PORT=8030
WEB_GREEN_PORT=8031
API_BLUE_PORT=8032
API_GREEN_PORT=8033

# Optional explicit binds (defaults: 127.0.0.1:PORT)
# WEB_BLUE_BIND=127.0.0.1:8004
# WEB_GREEN_BIND=127.0.0.1:8005
# API_BLUE_BIND=127.0.0.1:8006
# API_GREEN_BIND=127.0.0.1:8007

# Docker Compose project name (container prefix + nginx upstream name)
# COMPOSE_PROJECT_NAME=new-bank
