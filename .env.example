# Backend API (server-side only — never exposed to the browser)
API_URL="http://localhost:4000"

# Verifies session cookies in middleware (must match backend JWT_SECRET)
JWT_SECRET="replace-with-a-random-secret"

# Bypass auth and API calls so all pages are reachable during frontend dev.
# Also set MOCK_MODE=true in the Cloudflare dashboard (Variables) for production.
MOCK_MODE=true
