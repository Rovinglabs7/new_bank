  white-space: pre-wrap;
  word-break: break-word;

  :has(*) {
    white-space: normal;
  }

  h1 {
    font-size: 1.5em;
  }

  h2 {
    font-size: 1.25em;
  }

  h3 {
    font-size: 1.125em;
  }

  h4 {
    font-size: 1em;
  }

  h5 {
    font-size: 0.875em;
  }

  h6 {
    font-size: 0.75em;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6,
  p {
    margin-block: 0.5em;
  }

  * {
    margin: revert;
    padding: revert;
    line-height: initial;
    list-style-type: revert;
  }

  ul,
  ol {
    margin-block: 0.5em;
    padding-inline-start: 1.5em;
  }

  *:is(ol, ul) :is(ol, ul) {
    margin-block: 0;
  }

  li {
    padding-block: 0.125em;
  }

  del {
    text-decoration: line-through;
  }

  code {
    background: ${({theme:t})=>t.colors["bg/accent"]};
    border-radius: 8px;
    color: var(--base-neutral-0);
    padding: 2px 4px;
  }

  pre {
    overflow-x: auto;
  }

  pre code {
    overflow-x: auto;
    display: block;
    padding: 0.5em;
  }

  blockquote {
    padding-block: 0.5em;
    margin-block: 0.5em;
    margin-inline: 0;
    border-left: 2px solid ${({theme:t})=>t.colors["fg/action"]};
    background-color: ${({theme:t})=>t.colors["bg/action"]};
    padding-left: 1em;

    *:first-child {
      margin-block-start: 0;
    }

    *:last-child {
      margin-block-end: 0;
    }
  }

  table {
    display: block;
    overflow-x: auto;
    white-space: nowrap;
    border-collapse: collapse;
  }

  td,
  th {
    padding: 0.25em 0.5em;
  }

  td + td,
  th + th {
    border-left: 1px solid ${({theme:t})=>t.colors["fg/minor"]};
  }

  thead {
    border-bottom: 1px solid ${({theme:t})=>t.colors["fg/minor"]};
  }

  tr + tr {
    border-top: 1px solid ${({theme:t})=>t.colors["fg/minor"]};
  }

  p {
    padding: 0;
    color: inherit;
    font-weight: inherit;
    font-size: inherit;
    line-height: inherit;
    letter-spacing: inherit;
    white-space: pre-wrap;
  }

  & > *:first-child {
    margin-block-start: 0;
  }

  & > *:last-child {
    margin-block-end: 0;
  }

  a {
    color: rgb(var(--primary-color));
    box-shadow: inset 0px -2px 0px rgba(var(--primary-color), 0.12);
    :focus-visible {
      outline: none;
      box-shadow: ${({theme:t})=>t.shadows["border/focus-indicator"]};
    }
  }
