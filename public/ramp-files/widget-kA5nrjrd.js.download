  height: 0.25rem;
  width: 0.25rem;
  border-radius: 50%;
  background: ${({theme:t})=>t.colors["fg/major"]};
  animation:
    jump 1.5s ease-in-out infinite,
    pulse 1.5s ease-in-out infinite;
  ${({$disableAnimation:t})=>t?`
    animation: none;
    transform: none;
    opacity: 1;
  `:""}
  @media (prefers-reduced-motion: reduce) {
