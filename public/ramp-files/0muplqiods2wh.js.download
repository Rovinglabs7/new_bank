o:"mindbody-classpass"},{id:"tzu-san-hung-notion",name:"Tzu-San Hung",role:"Head of Strategic Finance",company:"Notion",quote:"Beautiful tools use beautiful tools.",logo:"notion"},{id:"matteo-franceschetti-eight-sleep",name:"Matteo Franceschetti",role:"CEO",company:"Eight Sleep",quote:"Ramp was a complete game changer. It's a single platform that can handle every aspect of our spending.",logo:"eight-sleep"},{id:"christine-mimnagh-fleming-shopify",name:"Christine Mimnagh-Fleming",role:"Sr. Manager, Finance Transformation",company:"Shopify",quote:"Ramp is so intuitive, people get it right away.",logo:"shopify"},{id:"carey-peek-kipp",name:"Carey Peek",role:"CFO",company:"KIPP Nashville Public Schools",quote:"Implementing Ramp has been my biggest win as CFO. Employees love it and often go out of their way to tell me so.",logo:"kipp"}],[{id:"neil-bradshaw-ketchum",name:"Mayor Neil Bradshaw",role:"Mayor",company:"City of Ketchum, ID",quote:"Ramp gives us the ability to make more informed financial policy decisions. It was one of the best decisions we've ever made.",logo:"ketchum"},{id:"bret-taylor-sierra",name:"Bret Taylor",role:"CEO",company:"Sierra",quote:"It's almost like we're a more self-actualized company because everyone is just working on what we do differently.",logo:"sierra"},{id:"michael-bohn-foursquare",name:"Michael Bohn",role:"Head of Business Operations",company:"Foursquare",quote:"The average person can figure Ramp out without training. That’s what drives 100% adoption.",logo:"foursquare"},{id:"ben-whipple-ketchum",name:"Ben Whipple",role:"Director of Public Works",company:"City of Ketchum, ID",quote:"I snap a picture of the receipt, Ramp handles the rest like magic, and I move on.",logo:"ketchum"},{id:"michael-litwin-virgin-voyages",name:"Michael Litwin",role:"VP Controller",company:"Virgin Voyages",quote:"Before Ramp it was a process from the dark ages. We had people just doing expenses full-time. It was miserable.",logo:"virgin-voyages"},{id:"staci-robi